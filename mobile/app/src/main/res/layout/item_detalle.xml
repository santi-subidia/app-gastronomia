<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_container"
    android:gravity="center_vertical"
    android:layout_marginVertical="4dp"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/detalle_nombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBody1"
        android:textColor="?attr/colorOnSurface"
        tools:text="Milanesa napolitana"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/detalle_cantidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textAppearance="?attr/textAppearanceBody2"
        android:textColor="@color/text_muted"
        tools:text="x2"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/detalle_subtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:minWidth="72dp"
        android:gravity="end"
        android:textAppearance="?attr/textAppearanceBody1"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        tools:text="$5000"
        xmlns:tools="http://schemas.android.com/tools" />

    <ImageButton
        android:id="@+id/detalle_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/delete_detalle"
        android:src="@android:drawable/ic_menu_delete" />

</LinearLayout>
