{
  "Database": {
    "RunSeeds": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ApiGastronomia": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "JwtSettings": {
    "Issuer": "ApiGastronomia",
    "Audience": "ApiGastronomiaClients",
    "SecretKey": "dev-secret-key-not-for-production-at-least-32-chars",
    "ExpiryMinutes": 480
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ApiGastronomiaDB;Username=postgres;Password=postgres"
  },
  "Routing": {
    "BaseUrl": "https://router.project-osrm.org/"
  }
}
